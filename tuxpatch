def cmd_update(config: dict):
    notif = config.get("notifications") or DEFAULTS["notifications"]
    notif_enabled = notif.get("enabled", True)
    migrate_package_names = [str(p).strip() for p in notif.get("migrate_packages", ["tuxmigrate"]) if str(p).strip()]
    migrate_pkgs = {p.lower() for p in migrate_package_names}
    flatpak_enabled = config["flatpak"].get("enabled", True)

    # ── 1. Connectivity ───────────────────────────────────────────────────────
    print("Checking connectivity...")
    if not check_connectivity(config):
        print("Not connected")
        return

    # ── 2. Pre-update: check which packages would be updated ─────────────────
    print("Checking pending updates...")
    rpm_updates = get_rpm_updates()
    reseal_enabled = config["tpm_reseal"]["enabled"]
    reseal_on_trigger_only = config["tpm_reseal"].get("reseal_on_trigger_only", False)

    if reseal_enabled:
        if reseal_on_trigger_only:
            needs_reseal = kernel_or_shim_will_update(rpm_updates)
        else:
            needs_reseal = bool(rpm_updates)
    else:
        needs_reseal = False

    kernel_will_update = any(
        _pkg_base_lower(p).startswith("kernel") for p in rpm_updates
    )
    migrate_will_update = any(
        _pkg_base_lower(p) in migrate_pkgs for p in rpm_updates
    )

    # ── 3. Pre-update TPM reseal: relax PCR binding ───────────────────────────
    # Done BEFORE the update so the next boot succeeds even if the update
    # changes PCR7 measurements (shim, GRUB, kernel).
    if needs_reseal:
        print("\nTPM reseal enabled — removing PCR binding before update:")
        if not unseal_for_update(config):
            print(
                "Warning: failed to remove PCR binding. "
                "Reseal will be skipped to avoid locking the system.",
                file=sys.stderr,
            )
            needs_reseal = False

    # ── 4. Update per-user flatpaks ───────────────────────────────────────────
    users = {}
    if flatpak_enabled and _flatpak_available():
        users = get_users_to_update(config)
        if users:
            print(f"Updating user flatpaks for {len(users)} user(s)...")
            for username, (uid, gid, home) in users.items():
                print(f"  [{username}] flatpak --user update")
                before = set(get_user_flatpak_updates(uid, gid, username, home))
                update_user_flatpaks(uid, gid, username, home)
                after = set(get_user_flatpak_updates(uid, gid, username, home))
                updated = before - after
                if updated and notif_enabled:
                    pkg_list = "\n".join(sorted(updated))
                    msg = notif["msg_flatpak_updated"].format(packages=pkg_list)
                    notify_user(uid, gid, home, username, "TuxPatch", msg)
        else:
            print("No applicable users found for flatpak updates.")

        # ── 5. Update system flatpaks ─────────────────────────────────────────
        print("Updating system flatpaks...")
        update_system_flatpaks()

        # ── 6. flat-manager-checkin ───────────────────────────────────────────
        if config["flatpak"].get("flat_manager_checkin", True):
            run_flat_manager_checkin()
    elif not flatpak_enabled:
        print("Flatpak updates disabled in config, skipping.")
    else:
        print("flatpak not found, skipping flatpak updates.")

    # ── 7. Update system packages ─────────────────────────────────────────────
    print("Updating system packages (dnf upgrade)...")
    rpm_did_update = update_system()
    if not rpm_did_update:
        print("Warning: dnf upgrade reported a non-zero exit code.", file=sys.stderr)

    if rpm_did_update and rpm_updates:
        run_migrate_post_install_scripts(migrate_package_names, rpm_updates)

    # ── 8. RPM notifications ──────────────────────────────────────────────────
    if notif_enabled and rpm_did_update and rpm_updates and users:
        if kernel_will_update:
            notify_all_users(users, "TuxPatch", notif["msg_kernel_updated"])
        if migrate_will_update:
            notify_all_users(users, "TuxPatch", notif["msg_migrate_updated"])
        if not kernel_will_update and not migrate_will_update:
            notify_all_users(users, "TuxPatch", notif["msg_rpm_updated"])

    # ── 9. TPM reseal: write state file and reboot ───────────────────────────
    if needs_reseal and rpm_did_update:
        print("\nPCR binding relaxed. Writing reseal state and rebooting...")
        try:
            install_reseal_service(config)
        except Exception as e:
            print(f"Error: could not write reseal state: {e}", file=sys.stderr)
            print(
                "Warning: PCR binding has been removed but the reseal state "
                "could not be written. Run 'tuxpatch --do-reseal' manually "
                "after the next boot.",
                file=sys.stderr,
            )
            return
        subprocess.run(["systemctl", "reboot"])
    elif needs_reseal and not rpm_did_update:
        # Update failed after we already relaxed the PCR binding.
        # Write the state file anyway so the reseal runs on next boot
        # and PCR protection is restored.
        print(
            "\nWarning: RPM update failed but PCR binding was already relaxed. "
            "Writing reseal state so protection is restored on next boot.",
            file=sys.stderr,
        )
        try:
            install_reseal_service(config)
        except Exception as e:
            print(f"Error: could not write reseal state: {e}", file=sys.stderr)
    else:
        print("\nUpdate complete.")


