def cmd_pcr_status(config: dict):
    """Show current and configured PCR state, clevis bindings, and pending reseal."""
    reseal_cfg = config.get("tpm_reseal", {})
    cfg_pcr_ids = reseal_cfg.get("pcr_ids", [7])
    key_file = reseal_cfg.get("luks_password_file", "(not set)")
    enabled = reseal_cfg.get("enabled", False)

    print("── TPM2 / Clevis PCR Status ─────────────────────────────────────")

    # ── 1. Config ─────────────────────────────────────────────────────────────
    print("\nConfig (tuxpatch):")
    print(f"  TPM reseal : {'enabled' if enabled else 'disabled'}")
    print(f"  PCR IDs    : {cfg_pcr_ids}")
    print(f"  Key file   : {key_file}")

    # ── 2. Current live PCR values ────────────────────────────────────────────
    print("\nLive TPM PCR measurements (SHA-256):")
    print("  (these are current TPM values, not LUKS binding state)")
    pcr_values = read_pcr_values(cfg_pcr_ids)
    if pcr_values:
        for pcr, val in sorted(pcr_values.items()):
            print(f"  PCR {pcr:<3}: {val}")
    else:
        print("  (unavailable — TPM sysfs not present and tpm2_pcrread not found)")

    # ── 3. TPM2 bindings per device ───────────────────────────────────────────
    devices = get_luks_devices_from_crypttab()
    if devices:
        print("\nTPM2 bindings (from /etc/crypttab):")
        for mapper_name, device in devices:
            print(f"  {device}  (mapper: {mapper_name}):")
            try:
                real_device = str(Path(device).resolve())
            except Exception:
                real_device = device
            # Clevis bindings
            bindings = get_clevis_bindings(device)
            if not bindings and real_device != device:
                bindings = get_clevis_bindings(real_device)
            if bindings:
                for slot, pin, cfg in bindings:
                    if pin == "tpm2":
                        pcr_str = cfg.get("pcr_ids", "")
                        policy = f"PCRs [{pcr_str}]" if pcr_str else "(no PCR restriction)"
                    else:
                        policy = ""
                    print(f"    Slot {slot}: {pin} (clevis)  {policy}".rstrip())
                continue
            # systemd-cryptenroll bindings
            ce_slots = get_cryptenroll_tpm2_slots(real_device)
            if not ce_slots and real_device != device:
                ce_slots = get_cryptenroll_tpm2_slots(device)
            if ce_slots:
                for slot in ce_slots:
                    print(f"    Slot {slot}: tpm2 (systemd-cryptenroll)")
                continue
            print("    (no TPM2 binding found — device not configured for TPM auto-unlock)")
    else:
        print("\nNo LUKS devices found in /etc/crypttab.")

    # ── 4. Pending reseal ─────────────────────────────────────────────────────
    pending = Path(RESEAL_PENDING_FILE)
    if pending.exists():
        try:
            state = _read_state_file()
            print("\nPending reseal: YES")
            print(f"  Kernel     : {state.get('kernel_version', '?')}")
            print(f"  Target PCRs: [{state.get('pcr_ids', '?')}]")
            print("  (tuxpatch-reseal.service will rebind clevis on next boot)")
        except Exception:
            print("\nPending reseal: YES (state file unreadable)")
    else:
        print("\nPending reseal: NO")


def cmd_pcr_remove(config: dict, device_filter: str | None, slot_filter: int | None):
    """Rebind clevis slots without PCR restrictions.

    The binding stays TPM2-backed (disk still auto-unlocks via TPM) but the
    PCR policy is dropped so PCR measurements no longer gate the unseal.
    Requires the LUKS key file from tpm_reseal.luks_password_file.
    """
    luks_key = config.get("tpm_reseal", {}).get("luks_password_file", "")
    if not luks_key or not Path(luks_key).exists():
        sys.exit(
            f"Error: LUKS key file not found: {luks_key!r}\n"
            f"Set tpm_reseal.luks_password_file in {CONFIG_PATH}"
        )
    luks_key = _resolve_key_file(luks_key)

    # Verify the key file against each device before touching any slots
    # (checked per-device below, but do an early inventory pass here).

    devices = get_luks_devices_from_crypttab()
    if not devices:
        print("No LUKS devices found in /etc/crypttab.")
        return

    if device_filter:
        filtered = []
        for m, d in devices:
            try:
                real_d = str(Path(d).resolve())
            except Exception:
                real_d = d
            if d == device_filter or m == device_filter or real_d == device_filter:
                filtered.append((m, d))
        if not filtered:
            sys.exit(f"Error: device {device_filter!r} not found in /etc/crypttab")
        devices = filtered

    any_action = False
    for mapper_name, device in devices:
        try:
            real_device = str(Path(device).resolve())
        except Exception:
            real_device = device

        # ── Clevis path ───────────────────────────────────────────────────────
        # Try the original path first (e.g. by-uuid), then the resolved path.
        bindings = get_clevis_bindings(device)
        if not bindings and real_device != device:
            bindings = get_clevis_bindings(real_device)
        if bindings:
            for slot, pin, cfg in bindings:
                if slot_filter is not None and slot != slot_filter:
                    continue
                if pin != "tpm2":
                    print(f"  {real_device} slot {slot}: not a tpm2 binding ({pin}), skipping.")
                    continue
                pcr_str = cfg.get("pcr_ids", "")
                if not pcr_str:
                    print(f"  {real_device} slot {slot}: already has no PCR restriction.")
                    continue

                print(f"  {real_device} ({mapper_name}) slot {slot}: removing PCR restriction [{pcr_str}]...")
                any_action = True

                # Verify the key file unlocks this device before touching any slots.
                if not _verify_key_unlocks(real_device, luks_key):
                    print(
                        f"    Error: {luks_key!r} does not unlock {real_device}.\n"
                        f"    Check tpm_reseal.luks_password_file in the config.\n"
                        f"    Hint: cryptsetup --key-file {luks_key} open --test-passphrase {real_device}",
                        file=sys.stderr,
                    )
                    continue

                # Bind the new no-PCR slot FIRST, then unbind the old one.
                # If the bind fails, the original binding is untouched.
                r = subprocess.run(
                    ["clevis", "luks", "bind", "-d", real_device, "-k", luks_key, "tpm2", "{}"],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    text=True,
                )
                if r.returncode == 0:
                    subprocess.run(
                        ["clevis", "luks", "unbind", "-d", real_device, "-s", str(slot), "-f"],
                        check=False,
                    )
                    print(f"    Done — original slot {slot} removed, rebound without PCR restriction.")
                else:
                    err = (r.stderr or r.stdout or "").strip()
                    print(f"    Error: clevis bind failed — original binding kept.", file=sys.stderr)
                    if err:
                        print(f"    clevis: {err}", file=sys.stderr)
            continue

        # ── systemd-cryptenroll path ──────────────────────────────────────────
        ce_slots = get_cryptenroll_tpm2_slots(real_device)
        if not ce_slots and real_device != device:
            ce_slots = get_cryptenroll_tpm2_slots(device)
        if not ce_slots:
            print(f"  {real_device} ({mapper_name}): no TPM2 binding found, skipping.")
            continue

        target_slots = [s for s in ce_slots if slot_filter is None or s == slot_filter]
        if not target_slots:
            continue

        print(f"  {real_device} ({mapper_name}): removing PCR restriction from "
              f"systemd-cryptenroll slot(s) {target_slots}...")
        any_action = True

        if not _verify_key_unlocks(real_device, luks_key):
            print(
                f"    Error: {luks_key!r} does not unlock {real_device}.\n"
                f"    Check tpm_reseal.luks_password_file in the config.\n"
                f"    Hint: cryptsetup --key-file {luks_key} open --test-passphrase {real_device}",
                file=sys.stderr,
            )
            continue

        # Enroll new TPM-only slot FIRST (no --tpm2-pcrs), then wipe old slot(s).
        r = subprocess.run(
            ["systemd-cryptenroll", "--tpm2-device=auto",
             f"--unlock-key-file={luks_key}", real_device],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
        if r.returncode == 0:
            for slot in target_slots:
                subprocess.run(
                    ["systemd-cryptenroll", f"--wipe-slot={slot}",
                     f"--unlock-key-file={luks_key}", real_device],
                    check=False,
                )
            print(f"    Done — slot(s) {target_slots} wiped, re-enrolled without PCR restriction.")
        else:
            err = (r.stderr or r.stdout or "").strip()
            print(f"    Error: systemd-cryptenroll enroll failed — original binding kept.", file=sys.stderr)
            if err:
                print(f"    cryptenroll: {err}", file=sys.stderr)

    if not any_action:
        print("Nothing to do — no slots with PCR restrictions found.")


# ── Entry point ───────────────────────────────────────────────────────────────


def _usage():
    name = Path(sys.argv[0]).name
    print(
        f"Usage: {name} <command> [args]\n"
        f"\n"
        f"Commands:\n"
        f"  update                  Apply all pending updates\n"
        f"  status                  Show pending updates and TPM reseal state\n"
        f"  pcr-status              Show current PCR values and clevis bindings\n"
        f"  pcr-remove [<device>] [<slot>]\n"
        f"                          Remove PCR restrictions from clevis binding(s)\n"
        f"  reseal                  Manually run the TPM2/LUKS reseal now\n"
        f"                          (same as the boot-time service; requires the\n"
        f"                          reseal.pending state file to be present)\n"
        f"  --version               Print version and exit",
        file=sys.stderr,
    )


def main():
    if os.geteuid() != 0:
        sys.exit("Error: tuxpatch must be run as root.")

    if len(sys.argv) < 2:
        _usage()
        sys.exit(1)

    command = sys.argv[1]

    if command == "--version":
        print(f"tuxpatch {VERSION}")
        return

    # --do-reseal: used by the systemd service on boot (requires state file).
    # reseal:      manual user command — arms the state file from config if
    #              it doesn't already exist, then runs the reseal.
    # Neither acquires the update lock — reseal is independent of update.
    if command == "--do-reseal":
        do_reseal()
        return

    if command == "reseal":
        config = load_config()
        luks_key = config["tpm_reseal"]["luks_password_file"]
        pcr_ids = _pcr_ids_str(config)
        preferred = config.get("tpm_reseal", {}).get("backend", "auto")
        if preferred == "auto":
            preferred = "cryptenroll"
        # Also arm the state file so the systemd service runs on the next
        # boot if the system is rebooted before a manual reseal completes.
        try:
            install_reseal_service(config)
        except Exception as e:
            print(f"Warning: could not write reseal state file: {e}", file=sys.stderr)
        do_reseal(luks_key=luks_key, pcr_ids=pcr_ids, reboot=False, preferred_backend=preferred)
        return

    # pcr-status and pcr-remove don't touch the update lock
    if command == "pcr-status":
        config = load_config()
        cmd_pcr_status(config)
        return

    if command == "pcr-remove":
        config = load_config()
        # pcr-remove [<device>] [<slot>]
        device_filter = sys.argv[2] if len(sys.argv) > 2 else None
        slot_filter: int | None = None
        if len(sys.argv) > 3:
            try:
                slot_filter = int(sys.argv[3])
            except ValueError:
                sys.exit(f"Error: slot must be an integer, got {sys.argv[3]!r}")
        cmd_pcr_remove(config, device_filter, slot_filter)
        return

    acquire_lock()
    try:
        config = load_config()
        setup_logging(config)

        if command == "update":
            cmd_update(config)
        elif command == "status":
            cmd_status(config)
        else:
            print(f"Unknown command: {command!r}", file=sys.stderr)
            _usage()
            sys.exit(1)
    finally:
        release_lock()


if __name__ == "__main__":
    main()
