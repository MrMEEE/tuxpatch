# ── RPM / DNF ─────────────────────────────────────────────────────────────────


def get_rpm_updates() -> list:
    """Return list of package names (with arch) that have pending updates."""
    r = subprocess.run(
        ["dnf", "check-update", "--quiet"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    # exit 100 = updates available, 0 = none, other = error
    packages = []
    in_obsoleting = False
    for line in r.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        if line.startswith("Obsoleting"):
            in_obsoleting = True
            continue
        if line.startswith("Last metadata") or line.startswith("Security:"):
            continue
        if in_obsoleting:
            continue
        parts = line.split()
        if len(parts) >= 2:
            packages.append(parts[0])
    return packages


def _pkg_base(pkg_name: str) -> str:
    """Strip epoch, version, release, arch from a package name."""
    # names from 'dnf check-update' look like: kernel.x86_64 or kernel-core.x86_64
    return pkg_name.split(".")[0]


def _pkg_base_lower(pkg: str) -> str:
    """Return lowercase base package name (strip arch suffix)."""
    return _pkg_base(pkg).lower()


def run_migrate_post_install_scripts(migrate_package_names: list[str], updated_rpm_packages: list[str]) -> None:
    """Run /usr/share/<package>/post-install.sh for migrate packages that updated."""
    updated_bases = {_pkg_base_lower(pkg) for pkg in updated_rpm_packages}

    for package_name in migrate_package_names:
        pkg = str(package_name).strip()
        if not pkg:
            continue
        if pkg.lower() not in updated_bases:
            continue

        script = Path(f"/usr/share/{pkg}/post-install.sh")
        if not script.exists():
            print(f"Warning: migrate hook not found for {pkg}: {script}", file=sys.stderr)
            continue

        print(f"Running migrate hook for {pkg}: {script}")
        r = subprocess.run([str(script)], text=True)
        if r.returncode != 0:
            print(
                f"Warning: migrate hook failed for {pkg} (exit {r.returncode})",
                file=sys.stderr,
            )


def kernel_or_shim_will_update(rpm_updates: list) -> bool:
    for pkg in rpm_updates:
        base = _pkg_base(pkg)
        for trigger in RESEAL_TRIGGERS:
            if base == trigger or base.startswith(trigger + "-"):
                return True
    return False


def update_system() -> bool:
    r = subprocess.run(["dnf", "upgrade", "-y", "--refresh"], text=True)
    return r.returncode == 0


# ── LUKS / Clevis / TPM2 ─────────────────────────────────────────────────────


def get_luks_devices_from_crypttab() -> list:
    """Return list of (mapper_name, resolved_device_path) from /etc/crypttab."""
    crypttab = Path("/etc/crypttab")
    devices = []
    if not crypttab.exists():
        return devices
    with open(crypttab) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            parts = line.split()
            if len(parts) < 2:
                continue
            name, device = parts[0], parts[1]
            if device.startswith("UUID="):
                device = f"/dev/disk/by-uuid/{device[5:]}"
            devices.append((name, device))
    return devices


def get_clevis_slots(device: str) -> list:
    """Return clevis-managed LUKS slot numbers for a device."""
    return [slot for slot, _pin, _cfg in get_clevis_bindings(device)]


def get_clevis_bindings(device: str) -> list:
    """Return list of (slot, pin, config_dict) for all clevis bindings on a device.

    clevis luks list output: "1: tpm2 '{\"pcr_ids\":\"7\"}'"
    """
    r = subprocess.run(
        ["clevis", "luks", "list", "-d", device],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    bindings = []
    for line in r.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        colon = line.find(":")
        if colon < 0:
            continue
        try:
            slot = int(line[:colon].strip())
        except ValueError:
            continue
        rest = line[colon + 1:].strip()
        parts = rest.split(None, 1)
        pin = parts[0] if parts else ""
        cfg_str = parts[1].strip("'") if len(parts) > 1 else ""
        try:
            cfg = json.loads(cfg_str)
        except (json.JSONDecodeError, ValueError):
            cfg = {}
        bindings.append((slot, pin, cfg))
    return bindings


def get_cryptenroll_tpm2_slots(device: str) -> list:
    """Return list of LUKS slot numbers enrolled with systemd-cryptenroll tpm2."""
    try:
        r = subprocess.run(
            ["systemd-cryptenroll", "--list", device],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except FileNotFoundError:
        return []
    slots = []
    for line in r.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 2 and parts[1] == "tpm2":
            try:
                slots.append(int(parts[0]))
            except ValueError:
                pass
    return slots


def _pcr_ids_cryptenroll_str(pcr_ids) -> str:
    """Format PCR IDs for systemd-cryptenroll --tpm2-pcrs= (uses '+' as separator)."""
    if isinstance(pcr_ids, str):
        parts = [p.strip() for p in pcr_ids.split(",")]
    else:
        parts = [str(p) for p in pcr_ids]
    return "+".join(parts)


def _detect_tpm2_backend(device: str, real_device: str, preferred_backend: str = "cryptenroll") -> tuple:
    """Detect which TPM2 backend is active for a device.

    Checks for clevis bindings first, then systemd-cryptenroll TPM2 slots.
    Returns (backend, slots) where backend is 'clevis' or 'cryptenroll'
    and slots is the list of existing slot numbers (empty if none configured).
    When no bindings are found, returns (preferred_backend, []).
    """
    clevis_slots = get_clevis_slots(device)
    if not clevis_slots and real_device != device:
        clevis_slots = get_clevis_slots(real_device)
    if clevis_slots:
        return "clevis", clevis_slots

    ce_slots = get_cryptenroll_tpm2_slots(real_device)
    if not ce_slots and real_device != device:
        ce_slots = get_cryptenroll_tpm2_slots(device)
    if ce_slots:
        return "cryptenroll", ce_slots

    return preferred_backend, []


def read_pcr_values(pcr_ids: list) -> dict:
    """Return {pcr_id: hex_string} for the requested PCR banks.

    Tries sysfs (kernel 5.12+) first, then falls back to tpm2_pcrread.
    """
    values: dict = {}
    sysfs_base = Path("/sys/class/tpm/tpm0/pcr-sha256")
    if sysfs_base.exists():
        for pcr in pcr_ids:
            p = sysfs_base / str(pcr)
            if p.exists():
                values[pcr] = p.read_text().strip().lower()
        return values

    # Fallback: tpm2_pcrread sha256:A+B+C
    pcr_spec = "sha256:" + "+".join(str(p) for p in pcr_ids)
    r = subprocess.run(
        ["tpm2_pcrread", pcr_spec],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    # Output:  sha256:\n  7 : 0xABCD...
    for ln in r.stdout.splitlines():
        ln = ln.strip()
        if ":" not in ln or ln.lower().startswith("sha"):
            continue
        k, _, v = ln.partition(":")
        try:
            values[int(k.strip())] = v.strip().lstrip("0x").lower()
        except ValueError:
            pass
    return values


def _pcr_ids_str(config: dict) -> str:
    return ",".join(str(p) for p in config["tpm_reseal"].get("pcr_ids", [7]))


_warned_key_files: set = set()
_temp_key_files: list = []


@atexit.register
def _cleanup_temp_keys():
    """Remove any stripped key copies written to /dev/shm at process exit."""
    for tmp in _temp_key_files:
        try:
            os.unlink(tmp)
        except OSError:
            pass


def _resolve_key_file(path: str) -> str:
    """Return the path to pass to --key-file / -k.

    If the file ends with a newline (a common mistake when the file was
    created with a text editor or echo), a stripped copy is written to
    /dev/shm (memory-backed, never written to disk) and that path is
    returned instead.  The warning is printed only once per path per run.
    The temp file is removed automatically at process exit.
    """
    data = Path(path).read_bytes()
    if not data.endswith(b'\n'):
        return path
    if path not in _warned_key_files:
        _warned_key_files.add(path)
        print(
            f"Warning: {path!r} ends with a newline — stripping it for LUKS operations.\n"
            f"  Fix permanently: truncate -s -1 {path}",
            file=sys.stderr,
        )
    shm = Path('/dev/shm')
    fd, tmp = tempfile.mkstemp(
        prefix='.tuxpatch-key-',
        dir=str(shm) if shm.exists() else None,
    )
    try:
        os.fchmod(fd, 0o600)
        os.write(fd, data.rstrip(b'\n'))
    finally:
        os.close(fd)
    _temp_key_files.append(tmp)
    return tmp


def _check_key_file(path: str):
    p = Path(path)
    if not p.exists():
        raise FileNotFoundError(f"LUKS key file not found: {path}")
    stat = p.stat()
    if stat.st_mode & 0o077:
        print(
            f"Warning: {path} has loose permissions. Recommend: chmod 600 {path}",
            file=sys.stderr,
        )
    if stat.st_uid != 0:
        print(f"Warning: {path} is not owned by root.", file=sys.stderr)
    if p.read_bytes().endswith(b'\n'):
        _warned_key_files.add(path)
        print(
            f"Warning: {path!r} ends with a newline — it will be stripped automatically.\n"
            f"  Fix permanently: truncate -s -1 {path}",
            file=sys.stderr,
        )


def _verify_key_unlocks(device: str, key_file: str) -> bool:
    """Return True if key_file can unlock the LUKS device."""
    r = subprocess.run(
        ["cryptsetup", "--key-file", _resolve_key_file(key_file), "open",
         "--test-passphrase", device],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return r.returncode == 0


def unseal_for_update(config: dict) -> bool:
    """
    Pre-update step: switch all clevis/TPM2 bindings from PCR-protected to
    TPM-only (no PCR restrictions).

    This ensures the next boot succeeds even if the update changes PCR7
    measurements (new shim, GRUB, kernel).  The disk is still protected by
    the TPM — it just won't verify boot-chain integrity until the reseal
    service restores PCR binding on the following boot.

    Returns True when all devices were switched successfully.
    """
    luks_key = config["tpm_reseal"]["luks_password_file"]
    try:
        _check_key_file(luks_key)
    except FileNotFoundError as e:
        print(f"TPM reseal: {e}", file=sys.stderr)
        return False
    luks_key = _resolve_key_file(luks_key)

    devices = get_luks_devices_from_crypttab()
    if not devices:
        print("TPM reseal: no LUKS devices found in /etc/crypttab — skipping.", file=sys.stderr)
        return False

    # Bind with TPM only, no PCR restrictions: hash+key parameters keep the
    # binding format consistent with the PCR-bound rebind that follows later.
    clevis_no_pcr = json.dumps({"hash": "sha256", "key": "ecc"})
    preferred_backend = config.get("tpm_reseal", {}).get("backend", "auto")
    if preferred_backend == "auto":
        preferred_backend = "cryptenroll"
    all_ok = True

    for mapper_name, device in devices:
        try:
            real_device = str(Path(device).resolve())
        except Exception:
            real_device = device

        backend, slots = _detect_tpm2_backend(device, real_device, preferred_backend)

        # Verify the key file actually unlocks this device before touching any slots.
        if not _verify_key_unlocks(real_device, luks_key):
            print(
                f"  Error: {luks_key!r} does not unlock {real_device}.\n"
                f"  Check tpm_reseal.luks_password_file in the config.\n"
                f"  Hint: cryptsetup --key-file {luks_key} open --test-passphrase {real_device}",
                file=sys.stderr,
            )
            all_ok = False
            continue

        if slots:
            print(f"  {real_device}: switching {backend} binding to TPM-only (slots {slots})...")
        else:
            print(f"  {real_device}: no TPM2 binding found — enrolling {backend} (TPM-only, no PCR)...")

        if backend == "clevis":
            # Bind the new no-PCR slot FIRST, then remove the old PCR-bound slots.
            # This ensures the disk is never left without a working binding if the rebind fails.
            r = subprocess.run(
                ["clevis", "luks", "bind", "-d", real_device, "-k", luks_key,
                 "tpm2", clevis_no_pcr],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
            )
            if r.returncode != 0:
                err = (r.stderr or r.stdout or "").strip()
                print(f"  Error: clevis bind (no-PCR) failed for {real_device} "
                      f"— original PCR binding kept.", file=sys.stderr)
                if err:
                    print(f"  clevis: {err}", file=sys.stderr)
                all_ok = False
                continue

            for slot in slots:
                subprocess.run(
                    ["clevis", "luks", "unbind", "-d", real_device, "-s", str(slot), "-f"],
                    check=False,
                )

        else:  # cryptenroll
            # Enroll new TPM-only slot FIRST (no --tpm2-pcrs), then wipe old slots.
            r = subprocess.run(
                ["systemd-cryptenroll", "--tpm2-device=auto",
                 f"--unlock-key-file={luks_key}", real_device],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
            )
            if r.returncode != 0:
                err = (r.stderr or r.stdout or "").strip()
                print(f"  Error: systemd-cryptenroll (no-PCR) failed for {real_device} "
                      f"— original binding kept.", file=sys.stderr)
                if err:
                    print(f"  cryptenroll: {err}", file=sys.stderr)
                all_ok = False
                continue

            for slot in slots:
                subprocess.run(
                    ["systemd-cryptenroll", f"--wipe-slot={slot}",
                     f"--unlock-key-file={luks_key}", real_device],
                    check=False,
                )

        print(f"  {real_device}: now TPM-bound without PCR restriction.")

    return all_ok


def install_reseal_service(config: dict) -> None:
    """
    Write the reseal state file so the pre-installed tuxpatch-reseal.service
    picks it up on the next boot.  The service unit is shipped and permanently
    enabled by the tuxpatch RPM; the ConditionPathExists= guard in the unit
    means it is a no-op at boot unless this state file is present.
    """
    pcr_ids = _pcr_ids_str(config)
    luks_key = config["tpm_reseal"]["luks_password_file"]

    backend = config.get("tpm_reseal", {}).get("backend", "auto")
    if backend == "auto":
        backend = "cryptenroll"

    Path(STATE_DIR).mkdir(parents=True, exist_ok=True)
    state = {
        "pcr_ids": pcr_ids,
        "luks_password_file": luks_key,
        "backend": backend,
    }
    with open(RESEAL_PENDING_FILE, "w") as f:
        for k, v in state.items():
            f.write(f"{k}={v}\n")
    Path(RESEAL_PENDING_FILE).chmod(0o600)
    print(f"Reseal state written — {RESEAL_SERVICE_NAME} will run on next boot.")



# ── Boot-time UI helpers ─────────────────────────────────────────────────────
# These are used only during the reseal boot, where the service runs on tty1
# before the graphical session starts.

_BOLD   = "\033[1m"
_RED    = "\033[1;31m"
_GREEN  = "\033[1;32m"
_YELLOW = "\033[1;33m"
_CYAN   = "\033[1;36m"
_RESET  = "\033[0m"


def _plymouth_active() -> bool:
    r = subprocess.run(
        ["plymouth", "--ping"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return r.returncode == 0


def _plymouth_message(text: str):
    subprocess.run(
        ["plymouth", "message", "--text", text],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def _write_tty(text: str):
    """Write directly to /dev/tty1, ignoring errors (tty may not exist)."""
    try:
        with open("/dev/tty1", "w") as tty:
            tty.write(text)
            tty.flush()
    except Exception:
        pass


def _boot_notify(message: str):
    """
    Show a status message during the reseal boot.
    Writes to: journal (print), Plymouth splash, and /dev/tty1.
    """
    print(message)
    tag = f"[TuxPatch] {message}"
    if _plymouth_active():
        _plymouth_message(tag)
    _write_tty(f"\n{_CYAN}{_BOLD}[TuxPatch]{_RESET} {message}\n")


def _boot_error_wait(message: str, reboot: bool = True):
    """
    Show an error during the reseal boot, hide Plymouth so the user can
    see the TTY, wait for Enter, then reboot.
    """
    print(f"ERROR: {message}", file=sys.stderr)

    # Hide Plymouth splash so the text console is visible
    if _plymouth_active():
        _plymouth_message(f"[TuxPatch] ERROR: {message}")
        subprocess.run(
            ["plymouth", "hide-splash"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

    if reboot:
        _write_tty(
            f"\n{_RED}{_BOLD}╔══ TuxPatch Reseal FAILED ══════════════════════════════╗{_RESET}\n"
            f"{_RED}{_BOLD}║{_RESET} {message:<54}{_RED}{_BOLD}║{_RESET}\n"
            f"{_RED}{_BOLD}╚════════════════════════════════════════════════════════╝{_RESET}\n"
            f"\n{_YELLOW}The temporary initrd and boot entry have been kept.\n"
            f"The system will try again on the next boot.{_RESET}\n"
            f"\n{_BOLD}Press Enter to reboot and try again...{_RESET} ",
        )

        # stdin is /dev/tty1 when the service runs with StandardInput=tty
        try:
            sys.stdin.readline()
        except Exception:
            import time
            time.sleep(30)

        subprocess.run(["systemctl", "reboot"])


def _read_state_file() -> dict:
    state = {}
    with open(RESEAL_PENDING_FILE) as f:
        for line in f:
            line = line.strip()
            if "=" in line:
                k, v = line.split("=", 1)
                state[k.strip()] = v.strip()
    return state


def do_reseal(luks_key: str = None, pcr_ids: str = None, reboot: bool = True,
              preferred_backend: str = None):
    """
    Perform the TPM2 reseal: rebind all TPM2 slots with the current PCR
    values, clean up state, and reboot.

    When called by the systemd service (--do-reseal), luks_key, pcr_ids, and
    preferred_backend are read from the state file.  When called by
    'tuxpatch reseal', they are passed directly from the loaded config.
    """
    if luks_key is None or pcr_ids is None:
        # Service path: values must come from the state file.
        if not Path(RESEAL_PENDING_FILE).exists():
            print("No reseal pending.", file=sys.stderr)
            return
        state = _read_state_file()
        if pcr_ids is None:
            pcr_ids = state.get("pcr_ids", "7")
        if luks_key is None:
            luks_key = state.get("luks_password_file", "")
        if preferred_backend is None:
            preferred_backend = state.get("backend", "cryptenroll")
    if not preferred_backend or preferred_backend == "auto":
        preferred_backend = "cryptenroll"

    if not luks_key or not Path(luks_key).exists():
        _boot_error_wait(
            f"LUKS key file not found: {luks_key!r}\n"
            "Set tpm_reseal.luks_password_file in the config.",
            reboot=reboot,
        )
        sys.exit(1)
    luks_key = _resolve_key_file(luks_key)

    # Hide Plymouth so the text banner is always visible on tty1
    if _plymouth_active():
        subprocess.run(
            ["plymouth", "hide-splash"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

    banner = (
        f"\n{_CYAN}{_BOLD}"
        f"╔══════════════════════════════════════════════════════════╗\n"
        f"║          TuxPatch — TPM2 / LUKS Reseal in Progress       ║\n"
        f"║                                                          ║\n"
        f"║  PCR measurements are being re-sealed against the new    ║\n"
        f"║  kernel / shim.  The system will reboot automatically    ║\n"
        f"║  when finished.  DO NOT power off.                       ║\n"
        f"╚══════════════════════════════════════════════════════════╝"
        f"{_RESET}\n"
    )
    _write_tty(banner)
    print("=== TPM2 Reseal started ===")
    if _plymouth_active():
        _plymouth_message("[TuxPatch] TPM2 Reseal in progress — do not power off")

    # Clevis config — hash/key/bank consistent with what was used pre-update.
    clevis_tpm_config = json.dumps({
        "hash": "sha256",
        "key": "ecc",
        "pcr_bank": "sha256",
        "pcr_ids": pcr_ids,
    })
    devices = get_luks_devices_from_crypttab()
    reseal_failed = False
    failed_device = ""

    for mapper_name, device in devices:
        try:
            real_device = str(Path(device).resolve())
        except Exception:
            real_device = device

        backend, slots = _detect_tpm2_backend(device, real_device, preferred_backend)

        # Verify the key file actually unlocks this device before attempting to bind.
        if not _verify_key_unlocks(real_device, luks_key):
            _boot_notify(
                f"Error: {luks_key!r} does not unlock {real_device}. "
                f"Add it as a LUKS keyslot: "
                f"cryptsetup luksAddKey {real_device} {luks_key}"
            )
            reseal_failed = True
            failed_device = real_device
            continue

        if slots:
            _boot_notify(f"Resealing {real_device} ({backend}, slots {slots}) with PCR [{pcr_ids}]...")
        else:
            _boot_notify(f"{real_device}: no TPM2 binding — enrolling {backend} with PCR [{pcr_ids}]...")

        if backend == "clevis":
            # Bind the new PCR-protected slot FIRST, then remove the old no-PCR slots.
            # If the bind fails, the original slot is preserved and the loop marks failure.
            r = subprocess.run(
                ["clevis", "luks", "bind", "-d", real_device, "-k", luks_key,
                 "tpm2", clevis_tpm_config],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
            )
            if r.returncode != 0:
                err = (r.stderr or r.stdout or "").strip()
                if err:
                    _boot_notify(f"clevis error: {err}")
                reseal_failed = True
                failed_device = real_device
                continue

            for slot in slots:
                subprocess.run(
                    ["clevis", "luks", "unbind", "-d", real_device, "-s", str(slot), "-f"],
                    check=False,
                )

        else:  # cryptenroll
            ce_pcr = _pcr_ids_cryptenroll_str(pcr_ids)
            # Enroll the new PCR-bound slot FIRST, then wipe the old no-PCR slots.
            r = subprocess.run(
                ["systemd-cryptenroll", "--tpm2-device=auto",
                 f"--tpm2-pcrs={ce_pcr}",
                 f"--unlock-key-file={luks_key}", real_device],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
            )
            if r.returncode != 0:
                err = (r.stderr or r.stdout or "").strip()
                if err:
                    _boot_notify(f"cryptenroll error: {err}")
                reseal_failed = True
                failed_device = real_device
                continue

            for slot in slots:
                subprocess.run(
                    ["systemd-cryptenroll", f"--wipe-slot={slot}",
                     f"--unlock-key-file={luks_key}", real_device],
                    check=False,
                )

    if reseal_failed:
        # Leave the state file in place so the service retries on the next boot.
        _boot_error_wait(f"TPM2 reseal failed for {failed_device}", reboot=reboot)
        sys.exit(1)

    _boot_notify("All devices resealed successfully.")

    # ── Cleanup ───────────────────────────────────────────────────────────────
    Path(RESEAL_PENDING_FILE).unlink(missing_ok=True)

    if reboot:
        _boot_notify("Reseal complete — rebooting into fully protected system.")
        subprocess.run(["systemctl", "reboot"])
    else:
        print("Reseal complete.")


