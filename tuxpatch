# ── Lock file ─────────────────────────────────────────────────────────────────


class _Tee:
    """Write to both a file and the original stream simultaneously."""
    def __init__(self, stream, fh):
        self._stream = stream
        self._fh = fh

    def write(self, data):
        self._stream.write(data)
        self._fh.write(data)
        self._fh.flush()

    def flush(self):
        self._stream.flush()
        self._fh.flush()

    def fileno(self):
        return self._stream.fileno()

    def isatty(self):
        return self._stream.isatty()


_log_fh = None  # kept open so it is never garbage-collected


def setup_logging(config: dict) -> None:
    global _log_fh
    log_path = config["logging"]["path"]
    reset = config["logging"]["reset_on_run"]
    mode = "w" if reset else "a"
    try:
        _log_fh = open(log_path, mode, buffering=1)
        import datetime
        _log_fh.write(f"\n=== tuxpatch run started {datetime.datetime.now().isoformat(timespec='seconds')} ===\n")
        sys.stdout = _Tee(sys.__stdout__, _log_fh)
        sys.stderr = _Tee(sys.__stderr__, _log_fh)
    except OSError as e:
        print(f"Warning: cannot open log file {log_path!r}: {e}", file=sys.stderr)


def acquire_lock() -> None:
    """
    Write our PID to LOCKFILE, or exit if another tuxpatch process is running.
    Uses O_CREAT|O_EXCL for atomic creation; falls back to stale-PID detection
    when the file already exists.
    """
    try:
        fd = os.open(LOCKFILE, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o644)
        os.write(fd, str(os.getpid()).encode())
        os.close(fd)
    except FileExistsError:
        try:
            pid = int(Path(LOCKFILE).read_text().strip())
        except (ValueError, OSError):
            pid = None

        if pid and Path(f"/proc/{pid}").exists():
            sys.exit("Tuxpatch already running")

        # Stale lockfile — previous run crashed without cleanup
        Path(LOCKFILE).write_text(str(os.getpid()))


def release_lock() -> None:
    try:
        Path(LOCKFILE).unlink()
    except OSError:
        pass


# ── Config ────────────────────────────────────────────────────────────────────


def load_config() -> dict:
    config_path = Path(CONFIG_PATH)
    if not config_path.exists():
        print(
            f"Warning: {CONFIG_PATH} not found, using defaults.", file=sys.stderr
        )
        return _deep_copy(DEFAULTS)

    with open(config_path) as f:
        user_config = yaml.safe_load(f) or {}

    config = _deep_copy(DEFAULTS)
    for section, values in user_config.items():
        if isinstance(values, dict) and section in config and isinstance(config[section], dict):
            config[section] = {**config[section], **values}
        else:
            config[section] = values
    return config


def _deep_copy(d):
    """Simple deep copy for dicts/lists of primitives."""
    if isinstance(d, dict):
        return {k: _deep_copy(v) for k, v in d.items()}
    if isinstance(d, list):
        return list(d)
    return d


# ── Connectivity ──────────────────────────────────────────────────────────────


def check_connectivity(config: dict) -> bool:
    method = config["connectivity"]["method"]
    server = config["connectivity"]["server"]
    timeout = int(config["connectivity"].get("timeout", 5))
    port = int(config["connectivity"].get("port", 443))

    try:
        if method == "ping":
            r = subprocess.run(
                ["ping", "-c", "1", "-W", str(timeout), server],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
            return r.returncode == 0

        elif method == "tcp":
            conn = socket.create_connection((server, port), timeout=timeout)
            conn.close()
            return True

        elif method == "http":
            url = server if server.startswith("http") else f"http://{server}"
            req = urllib.request.Request(url, method="HEAD")
            try:
                with urllib.request.urlopen(req, timeout=timeout) as resp:
                    return resp.status < 500
            except urllib.error.HTTPError as e:
                return e.code < 500

        else:
            print(f"Unknown connectivity method: {method!r}", file=sys.stderr)
            return False

    except Exception:
        return False


# ── Users ─────────────────────────────────────────────────────────────────────


def _get_sssd_group_members(groups: list) -> set:
    """Return set of usernames that belong to any of the given AD/LDAP groups."""
    members: set = set()
    for group in groups:
        r = subprocess.run(
            ["getent", "group", group],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        if r.returncode == 0 and r.stdout.strip():
            # groupname:password:gid:member1,member2,...
            parts = r.stdout.strip().split(":")
            if len(parts) >= 4 and parts[3]:
                members.update(parts[3].split(","))
    return members


def get_users_to_update(config: dict) -> dict:
    """
    Return {username: (uid, gid, home)} for every user that should get
    flatpak updates.  UID and GID are captured here, while getent is
    available, so flatpak commands can be run via direct setuid/setgid
    without any further NSS/getpwnam lookups (important for cron).

    A user is included if any of the following are true:
      - Their UID is within users.uid_range  (local accounts)
      - They are a member of one of users.sssd_groups  (AD/LDAP accounts)
        Home dir is resolved via 'getent passwd <username>'.
    """
    uid_min, uid_max = config["users"]["uid_range"]
    sssd_groups = config["users"].get("sssd_groups", [])

    no_login_shells = {"/sbin/nologin", "/bin/false", "/usr/sbin/nologin"}
    users: dict = {}

    # ── Local accounts by UID range ───────────────────────────────────────────
    r = subprocess.run(
        ["getent", "passwd"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    for line in r.stdout.splitlines():
        parts = line.split(":")
        if len(parts) < 7:
            continue
        username, _, uid_str, gid_str, _, home, shell = parts[:7]
        try:
            uid, gid = int(uid_str), int(gid_str)
        except ValueError:
            continue
        if uid_min <= uid <= uid_max and home and Path(home).exists():
            if shell not in no_login_shells:
                users[username] = (uid, gid, home)

    # ── AD/LDAP accounts by group membership ─────────────────────────────────
    for username in _get_sssd_group_members(sssd_groups):
        if username in users:
            continue
        pw = subprocess.run(
            ["getent", "passwd", username],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        if pw.returncode != 0 or not pw.stdout.strip():
            continue
        pw_parts = pw.stdout.strip().split(":")
        if len(pw_parts) < 7:
            continue
        _, _, uid_str, gid_str, _, home, shell = pw_parts[:7]
        try:
            uid, gid = int(uid_str), int(gid_str)
        except ValueError:
            continue
        if home and Path(home).exists() and shell not in no_login_shells:
            users[username] = (uid, gid, home)

    return users


# ── Flatpak ───────────────────────────────────────────────────────────────────


def _flatpak_available() -> bool:
    return bool(subprocess.run(
        ["which", "flatpak"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    ).returncode == 0)


def get_system_flatpak_updates() -> list:
    r = subprocess.run(
        ["flatpak", "--system", "remote-ls", "--updates", "--columns=application"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    return [ln.strip() for ln in r.stdout.splitlines() if ln.strip()]


def _user_env(uid: int, username: str, home: str) -> dict:
    """Minimal env for running flatpak --user without a login session.

    GLib falls back to USER/LOGNAME/HOME when getpwuid() fails (e.g. SSSD
    cache miss in cron), so setting them here prevents the
    'getpwnam() failed' error from flatpak.
    """
    return {
        "PATH": "/usr/bin:/bin",
        "HOME": home,
        "USER": username,
        "LOGNAME": username,
        "USERNAME": username,
        "XDG_RUNTIME_DIR": f"/run/user/{uid}",
        "XDG_DATA_HOME": f"{home}/.local/share",
        # Flatpak uses a peer-to-peer D-Bus socket in XDG_RUNTIME_DIR.
        "DBUS_SESSION_BUS_ADDRESS": f"unix:path=/run/user/{uid}/bus",
    }


def get_user_flatpak_updates(uid: int, gid: int, username: str, home: str) -> list:
    env = _user_env(uid, username, home)
    def _demote():
        os.setgid(gid)
        os.setuid(uid)
    r = subprocess.run(
        ["flatpak", "--user", "remote-ls", "--updates", "--columns=application"],
        preexec_fn=_demote,
        env=env,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    return [ln.strip() for ln in r.stdout.splitlines() if ln.strip()]


def update_user_flatpaks(uid: int, gid: int, username: str, home: str) -> bool:
    env = _user_env(uid, username, home)
    def _demote():
        os.setgid(gid)
        os.setuid(uid)
    r = subprocess.run(
        ["flatpak", "--user", "update", "-y", "--noninteractive"],
        preexec_fn=_demote,
        env=env,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    return r.returncode == 0


def update_system_flatpaks() -> bool:
    r = subprocess.run(
        ["flatpak", "--system", "update", "-y", "--noninteractive"],
        text=True,
    )
    return r.returncode == 0


# ── Notifications ─────────────────────────────────────────────────────────────


def notify_user(uid: int, gid: int, home: str, username: str, summary: str, body: str = "") -> None:
    """Send a persistent desktop notification to a user's session bus.

    Prefer direct D-Bus calls via gdbus (more reliable KDE hint handling),
    then fall back to notify-send.
    """
    bus = f"/run/user/{uid}/bus"
    if not Path(bus).exists():
        return

    def _demote():
        os.setgid(gid)
        os.setuid(uid)

    env = _user_env(uid, username, home)

    gdbus_cmd = [
        "gdbus",
        "call",
        "--session",
        "--dest",
        "org.freedesktop.Notifications",
        "--object-path",
        "/org/freedesktop/Notifications",
        "--method",
        "org.freedesktop.Notifications.Notify",
        "tuxpatch",  # app_name
        "0",  # replaces_id
        "system-software-update",  # app_icon
        summary,
        body,
        "[]",  # actions
        "{'urgency': <byte 2>, 'resident': <true>, 'transient': <false>, 'desktop-entry': <'tuxpatch'>, 'x-kde-origin-name': <'tuxpatch'>}",
        "0",  # expire_timeout (0 = never expire)
    ]
    r = subprocess.run(
        gdbus_cmd,
        preexec_fn=_demote,
        env=env,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    if r.returncode == 0:
        return

    cmd = [
        "notify-send",
        "--urgency=critical",
        # 0 requests "never expire" per org.freedesktop.Notifications.
        "--expire-time=0",
        # Provide a stable app identity so KDE can keep proper history entries.
        "--hint=string:desktop-entry:tuxpatch",
        "--hint=string:x-kde-origin-name:tuxpatch",
        # Hint to keep it in the notification center/tray where supported.
        "--hint=boolean:resident:true",
        # Explicitly mark as non-transient so it should be stored in history.
        "--hint=boolean:transient:false",
        "--app-name=tuxpatch",
        "--icon=system-software-update",
        summary,
    ]
    if body:
        cmd.append(body)

    subprocess.run(
        cmd,
        preexec_fn=_demote,
        env=env,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def notify_all_users(users: dict, summary: str, body: str = "") -> None:
    """Send the same notification to every user in the users dict."""
    for username, (uid, gid, home) in users.items():
        notify_user(uid, gid, home, username, summary, body)


